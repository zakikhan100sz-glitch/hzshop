# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port (Render assigns this automatically, default 5000 for local)
PORT=5000

# Node Environment
NODE_ENV=development

# CORS - Set to your frontend URL on Render
# Local: empty or http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend API URL (for client-side requests)
# Leave empty for local (defaults to http://localhost:5000)
# Set to your Render domain for production: https://yourdomain.onrender.com
VITE_API_URL=

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp Order Link
WHATSAPP_NUMBER=1234567890

# Seed Admin Credentials (for initial setup)
SEED_ADMIN_EMAIL=admin@hzshop.com
SEED_ADMIN_PASSWORD=YourSecurePassword123
SEED_WIPE_PRODUCTS=false
